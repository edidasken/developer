rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════
    // DEMO MODE - ALL PERMISSIONS OPEN FOR SIGNED-IN USERS
    // ═══════════════════════════════════════════════════════════
    
    // Helper function: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // ── Church Settings ────────────────────────────────────────
    match /church/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Members ────────────────────────────────────────────────
    match /members/{memberId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Households ─────────────────────────────────────────────
    match /households/{householdId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Users (AuthUsers) ──────────────────────────────────────
    match /users/{userId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Permissions ────────────────────────────────────────────
    match /permissions/{userId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Service Plans ──────────────────────────────────────────
    match /servicePlans/{planId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Quarterly Plans ────────────────────────────────────────
    match /quarterlyPlans/{planId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Songs ──────────────────────────────────────────────────
    match /songs/{songId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Sermons ────────────────────────────────────────────────
    match /sermons/{sermonId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Sermon Series ──────────────────────────────────────────
    match /sermonSeries/{seriesId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Sermon Reviews ─────────────────────────────────────────
    match /sermonReviews/{reviewId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Giving ─────────────────────────────────────────────────
    match /giving/{recordId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Pledges ────────────────────────────────────────────────
    match /pledges/{pledgeId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Events ─────────────────────────────────────────────────
    match /events/{eventId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Attendance ─────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Conversations ──────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Messages ───────────────────────────────────────────────
    match /messages/{messageId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Care Notes ─────────────────────────────────────────────
    match /care/{noteId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Compassion ─────────────────────────────────────────────
    match /compassion/{recordId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Outreach ───────────────────────────────────────────────
    match /outreach/{recordId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Touches ────────────────────────────────────────────────
    match /touches/{touchId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Prayer Requests ────────────────────────────────────────
    match /prayers/{prayerId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Strategic Planning ─────────────────────────────────────
    match /strategicGoals/{goalId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /strategicInitiatives/{initiativeId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /strategicDates/{dateId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Discipleship ───────────────────────────────────────────
    match /discipleshipPaths/{pathId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /discipleshipSteps/{stepId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /discipleshipEnrollments/{enrollmentId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Teaching & Growth ──────────────────────────────────────
    match /devotionals/{devotionalId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /readingPlans/{planId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /teachingPlans/{planId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Missions ───────────────────────────────────────────────
    match /missionTrips/{tripId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /missionPartners/{partnerId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /missionProjects/{projectId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /missionUpdates/{updateId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Library ────────────────────────────────────────────────
    match /theology/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /apologetics/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /counseling/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /books/{bookId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /psalms/{psalmId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /words/{wordId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /library/{docId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── System & Stats ─────────────────────────────────────────
    match /todos/{todoId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /journal/{entryId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /stats/{statId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /settings/{settingId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ── Catch-all for any other collections ────────────────────
    match /{document=**} {
      allow read, create, update, delete: if isSignedIn();
    }
  }
}
